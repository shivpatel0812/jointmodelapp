# Optional: call Railway (or any backend) directly from the browser. Set on Vercel if you
# do NOT rely on vercel.json rewrites. Example: https://jointmodelapp-production.up.railway.app
# VITE_API_BASE_URL=

# 1. Copy this file to `.env.local` in this folder (same level as package.json).
# 2. Firebase Console → Project settings (gear) → Your apps → Web app → copy the `firebaseConfig` object.
# 3. Restart `npm run dev` after changing env vars.
#
# Vercel: add the same keys under Project → Settings → Environment Variables.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — omit to skip Google Analytics in the client
VITE_FIREBASE_MEASUREMENT_ID=
