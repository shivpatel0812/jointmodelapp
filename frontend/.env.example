# Copy to `.env` or `.env.local` (Vite loads both; neither is committed).
# These are the Firebase *web client* settings from the Firebase console (public in the browser bundle).
# Security comes from Firebase rules + Auth, not from hiding the API key.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=
