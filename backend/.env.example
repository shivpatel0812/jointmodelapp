# Optional: comma-separated extra browser origins (e.g. your custom prod domain).
# Vercel `*.vercel.app` is allowed by default in main.py when using VITE_API_BASE_URL from the frontend.
# CORS_ORIGINS=

# Copy to .env and fill in at least one provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Google AI Studio / Gemini Developer API (either name works)
GEMINI_API_KEY=
GOOGLE_API_KEY=
# Optional OpenAI judge + synthesis for POST /api/evaluate (defaults to gpt-4o-mini)
JUDGE_MODEL_ID=
SYNTHESIS_MODEL_ID=
